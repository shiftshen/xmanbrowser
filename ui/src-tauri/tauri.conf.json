{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Xbrowser",
  "version": "1.0.0",
  "identifier": "com.xman.fingerprint",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5191",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Xbrowser — powered by xmanx",
        "width": 1200,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["sidecar/**/*"],
    "category": "DeveloperTool",
    "shortDescription": "Open-source fingerprint browser",
    "longDescription": "Xbrowser — free & open-source fingerprint browser (powered by xmanx). Isolated profiles with consistent fingerprints, per-profile proxy, and storage isolation.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
